# Normalize to LF in the repository for every text file, regardless of the
# contributor's core.autocrlf setting.
* text=auto eol=lf

# Shell scripts MUST be LF or they fail to run on Unix (`/usr/bin/env: sh\r`).
*.sh   text eol=lf

# Source / config / docs: LF everywhere.
*.rs   text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.lock text eol=lf

# PowerShell scripts are Windows-native: keep CRLF in the working tree.
*.ps1  text eol=crlf
